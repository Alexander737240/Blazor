@page "/groups/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Создание группы</PageTitle>

<h1>Создание группы</h1>

<div style="margin-bottom: 20px;">
    <a href="/groups">Назад к списку</a>
</div>

@if (errorMessage != null)
{
    <div style="padding: 10px; background-color: #f8d7da; color: #721c24; border-radius: 5px; margin-bottom: 15px;">
        @errorMessage
    </div>
}

<div style="width: 500px;">
    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Название группы:</label>
        <input @bind="groupName" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Направление обучения:</label>
        <select @bind="selectedDisciplineId" style="width: 100%; padding: 8px;">
            <option value="">-- Выберите направление --</option>
            @foreach (var discipline in disciplines)
            {
                <option value="@discipline.discipline_id">@discipline.discipline_name</option>
            }
        </select>
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Учебные дни:</label>
        <div style="display: flex; flex-wrap: wrap; gap: 10px; padding: 10px; border: 1px solid #ddd; border-radius: 5px;">
            @foreach (var day in studyDays)
            {
                <label style="margin-right: 15px;">
                    <input type="checkbox"
                           value="@day.day_id"
                           checked="@selectedDays.Contains(day.day_id)"
                           @onchange="@(() => ToggleDay(day.day_id))" />
                    @day.day_name
                </label>
            }
        </div>
    </div>

    <div style="margin-top: 20px;">
        <button @onclick="SaveGroup" style="padding: 8px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px;">Сохранить</button>
        <button @onclick="Cancel" style="margin-left: 10px; padding: 8px 20px;">Отмена</button>
    </div>
</div>

@code {
    private BlazorAcademyHWContext context = default!;
    private string groupName = "";
    private string? selectedDisciplineId = "";
    private List<int> selectedDays = new();
    private List<Disciplines> disciplines = new();
    private List<StudyDay> studyDays = new();
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        disciplines = await context.Disciplines.ToListAsync();
        studyDays = await context.StudyDays.OrderBy(d => d.day_order).ToListAsync();
    }

    private void ToggleDay(int dayId)
    {
        if (selectedDays.Contains(dayId))
            selectedDays.Remove(dayId);
        else
            selectedDays.Add(dayId);
    }

    private async Task SaveGroup()
    {
        errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(groupName))
        {
            errorMessage = "Введите название группы";
            return;
        }
        int nextId = 1;
        if (await context.Groups.AnyAsync())
        {
            nextId = await context.Groups.MaxAsync(g => g.group_id) + 1;
        }

        var group = new Groups
        {
            group_id = nextId,
            group_name = groupName,
            direction = string.IsNullOrEmpty(selectedDisciplineId) ? null : (byte?)byte.Parse(selectedDisciplineId)
        };

        context.Groups.Add(group);
        await context.SaveChangesAsync();

        foreach (var dayId in selectedDays)
        {
            var groupsDay = new GroupsDay
            {
                group_id = group.group_id,
                day_id = dayId
            };
            context.GroupsDays.Add(groupsDay);
        }
        
        if (selectedDays.Any())
        {
            await context.SaveChangesAsync();
        }

        Navigation.NavigateTo("/groups");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/groups");
    }
}
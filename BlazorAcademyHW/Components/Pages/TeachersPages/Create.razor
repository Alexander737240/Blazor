@page "/teachers/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Создание преподавателя</PageTitle>

<h1>Создание преподавателя</h1>

<div style="margin-bottom: 20px;">
    <a href="/teachers">Назад к списку</a>
</div>

@if (errorMessage != null)
{
    <div style="padding: 10px; background-color: #f8d7da; color: #721c24; border-radius: 5px; margin-bottom: 15px;">
        @errorMessage
    </div>
}

<div style="width: 500px;">
    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Фамилия:</label>
        <input @bind="lastName" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Имя:</label>
        <input @bind="firstName" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Отчество:</label>
        <input @bind="middleName" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Дата рождения:</label>
        <input type="date" @bind="birthDate" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Работает с:</label>
        <input type="date" @bind="workSince" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Ставка:</label>
        <input type="number" step="0.01" @bind="rate" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Дисциплины, которые ведет преподаватель:</label>
        <div style="padding: 10px; border: 1px solid #ddd; border-radius: 5px; max-height: 200px; overflow-y: auto;">
            @foreach (var discipline in allDisciplines)
            {
                <label style="display: block; margin-bottom: 5px;">
                    <input type="checkbox"
                           value="@discipline.discipline_id"
                           checked="@selectedDisciplines.Contains(discipline.discipline_id)"
                           @onchange="@(() => ToggleDiscipline(discipline.discipline_id))" />
                    @discipline.discipline_name (часов: @discipline.number_of_lessons)
                </label>
            }
        </div>
    </div>

    <div style="margin-top: 20px;">
        <button @onclick="SaveTeacher" style="padding: 8px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px;">Сохранить</button>
        <button @onclick="Cancel" style="margin-left: 10px; padding: 8px 20px;">Отмена</button>
    </div>
</div>

@code {
    private BlazorAcademyHWContext context = default!;
    private string lastName = "";
    private string firstName = "";
    private string middleName = "";
    private DateOnly? birthDate;
    private DateOnly? workSince;
    private decimal? rate;
    private List<short> selectedDisciplines = new();
    private List<Disciplines> allDisciplines = new();
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        allDisciplines = await context.Disciplines.ToListAsync();
    }

    private void ToggleDiscipline(short disciplineId)
    {
        if (selectedDisciplines.Contains(disciplineId))
            selectedDisciplines.Remove(disciplineId);
        else
            selectedDisciplines.Add(disciplineId);
    }

    private async Task SaveTeacher()
    {
        errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(lastName))
        {
            errorMessage = "Введите фамилию";
            return;
        }
        
        if (string.IsNullOrWhiteSpace(firstName))
        {
            errorMessage = "Введите имя";
            return;
        }

        int nextId = 1;
        if (await context.Teachers.AnyAsync())
        {
            nextId = await context.Teachers.MaxAsync(t => t.teacher_id) + 1;
        }

        var teacher = new Teachers
        {
            teacher_id = (short)nextId,
            last_name = lastName,
            first_name = firstName,
            middle_name = middleName,
            birth_date = birthDate,
            work_since = workSince,
            rate = rate
        };

        context.Teachers.Add(teacher);
        await context.SaveChangesAsync();

        foreach (var disciplineId in selectedDisciplines)
        {
            var teacherDiscipline = new TeacherDiscipline
            {
                teacher_id = teacher.teacher_id,
                discipline_id = disciplineId
            };
            context.TeacherDisciplines.Add(teacherDiscipline);
        }
        
        if (selectedDisciplines.Any())
        {
            await context.SaveChangesAsync();
        }

        Navigation.NavigateTo("/teachers");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/teachers");
    }
}
@page "/teachers"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@implements IAsyncDisposable
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory

<PageTitle>Преподаватели</PageTitle>

<h1>Преподаватели</h1>

<p>
    <a href="teachers/create">Create New</a>
</p>

<div style="margin-bottom: 20px; padding: 15px; background-color: #f5f5f5; border-radius: 5px;">
    <label style="margin-right: 10px;">Показывать записей:</label>
    <select @bind="pageSize" style="padding: 5px; width: 100px; margin-right: 10px;">
        <option value="5">5</option>
        <option value="10">10</option>
        <option value="20">20</option>
        <option value="50">50</option>
    </select>
</div>

<div style="margin-bottom: 10px;">
    Найдено: @displayedTeachers.Count() записей
</div>

<QuickGrid Class="table" Items="@GetPagedTeachers()" TGridItem="TeacherViewModel">
    <PropertyColumn Class="last-name" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.last_name" Title="Фамилия" Sortable="true" />
    <PropertyColumn Class="first-name" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.first_name" Title="Имя" Sortable="true" />
    <PropertyColumn Class="middle-name" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.middle_name" Title="Отчество" Sortable="true" />
    <PropertyColumn Class="birth-date" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.age" Title="Возраст" Sortable="true" />
    <PropertyColumn Class="work-since" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.work_since_display" Title="Работает с" Sortable="true" />
    <PropertyColumn Class="work-since" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.experience" Title="Стаж" Sortable="true" />
    <PropertyColumn Class="rate" TGridItem="TeacherViewModel" TProp="string?" Property="t => t.rate" Title="Ставка" Sortable="true" />

    <TemplateColumn TGridItem="TeacherViewModel" Context="teacher">
        <a href="@($"/teachers/edit/{teacher.teacher_id}")">Edit</a> |
        <a href="@($"/teachers/details/{teacher.teacher_id}")">Details</a> |
        <a href="@($"/teachers/delete/{teacher.teacher_id}")">Delete</a>
    </TemplateColumn>
</QuickGrid>

<div style="margin-top: 15px; display: flex; gap: 10px; align-items: center;">
    <button @onclick="PreviousPage" disabled="@(currentPage == 0)">◀ Предыдущая</button>
    <span>Страница @(currentPage + 1) из @totalPages</span>
    <button @onclick="NextPage" disabled="@(currentPage >= totalPages - 1)">Следующая ▶</button>
</div>

@code {
    private BlazorAcademyHWContext context = default!;
    private List<TeacherViewModel> allTeachers = new();
    private List<TeacherViewModel> displayedTeachers = new();
    private int pageSize = 10;
    private int currentPage = 0;
    private int totalPages = 0;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        await LoadData();
    }

    private async Task LoadData()
    {
        var teachers = await context.Teachers.ToListAsync();

        allTeachers = teachers.Select(t => new TeacherViewModel
        {
            teacher_id = t.teacher_id,
            last_name = t.last_name ?? "Не указано",
            first_name = t.first_name ?? "Не указано",
            middle_name = t.middle_name ?? "Не указано",
            birth_date = t.birth_date,
            age = CalculateAge(t.birth_date),
            work_since = t.work_since,
            work_since_display = t.work_since?.ToString("dd.MM.yyyy") ?? "Не указано",
            experience = CalculateExperience(t.work_since),
            rate = t.rate?.ToString("0.00") ?? "Не указано"
        }).ToList();

        ApplyFilter();
    }

    private string CalculateAge(DateOnly? birthDate)
    {
        if (!birthDate.HasValue)
            return "Не указано";

        var today = DateOnly.FromDateTime(DateTime.Today);
        var age = today.Year - birthDate.Value.Year;

        if (birthDate.Value > today.AddYears(-age))
            age--;

        return $"{age} лет";
    }

    private string CalculateExperience(DateOnly? workSince)
    {
        if (!workSince.HasValue)
            return "Не указано";

        var today = DateOnly.FromDateTime(DateTime.Today);
        var years = today.Year - workSince.Value.Year;

        if (workSince.Value > today.AddYears(-years))
            years--;

        return $"{years} лет";
    }

    private void ApplyFilter()
    {
        displayedTeachers = allTeachers.ToList();

        currentPage = 0;
        UpdatePagination();
        StateHasChanged();
    }

    private void UpdatePagination()
    {
        totalPages = (int)Math.Ceiling((double)displayedTeachers.Count / pageSize);
        if (totalPages == 0) totalPages = 1;
        if (currentPage >= totalPages) currentPage = totalPages - 1;
        if (currentPage < 0) currentPage = 0;
    }

    private IQueryable<TeacherViewModel> GetPagedTeachers()
    {
        return displayedTeachers
            .Skip(currentPage * pageSize)
            .Take(pageSize)
            .AsQueryable();
    }

    private void PreviousPage()
    {
        if (currentPage > 0)
        {
            currentPage--;
            StateHasChanged();
        }
    }

    private void NextPage()
    {
        if (currentPage < totalPages - 1)
        {
            currentPage++;
            StateHasChanged();
        }
    }

    public class TeacherViewModel
    {
        public short teacher_id { get; set; }
        public string? last_name { get; set; }
        public string? first_name { get; set; }
        public string? middle_name { get; set; }
        public DateOnly? birth_date { get; set; }
        public string? age { get; set; }
        public DateOnly? work_since { get; set; }
        public string? work_since_display { get; set; }
        public string? experience { get; set; }
        public string? rate { get; set; }
    }

    public async ValueTask DisposeAsync()
    {
        if (context != null)
            await context.DisposeAsync();
    }
}
@page "/teachers/edit/{teacher_id:int}"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Редактирование преподавателя</PageTitle>

<h1>Редактирование преподавателя</h1>

<div style="margin-bottom: 20px;">
    <a href="/teachers">Назад к списку</a>
</div>

<div style="margin-bottom: 10px;">
    <strong>ID преподавателя:</strong> @teacher_id
</div>

@if (isLoading)
{
    <div>Загрузка...</div>
}
else if (teacher == null)
{
    <div style="color: red; padding: 10px; background-color: #f8d7da; border-radius: 5px;">
        Преподаватель с ID @teacher_id не найден
    </div>
}
else
{
    <div style="width: 500px;">
        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Фамилия:</label>
            <input @bind="teacher.last_name" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Имя:</label>
            <input @bind="teacher.first_name" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Отчество:</label>
            <input @bind="teacher.middle_name" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Дата рождения:</label>
            <input type="date" @bind="teacher.birth_date" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Работает с:</label>
            <input type="date" @bind="teacher.work_since" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Ставка:</label>
            <input type="number" step="0.01" @bind="teacher.rate" style="width: 100%; padding: 8px;" />
        </div>

        <div style="margin-bottom: 15px;">
            <label style="display: block; margin-bottom: 5px;">Дисциплины, которые ведет преподаватель:</label>
            <div style="padding: 10px; border: 1px solid #ddd; border-radius: 5px; max-height: 200px; overflow-y: auto;">
                @foreach (var discipline in allDisciplines)
                {
                    <label style="display: block; margin-bottom: 5px;">
                        <input type="checkbox"
                               value="@discipline.discipline_id"
                               checked="@selectedDisciplines.Contains(discipline.discipline_id)"
                               @onchange="@(() => ToggleDiscipline(discipline.discipline_id))" />
                        @discipline.discipline_name (часов: @discipline.number_of_lessons)
                    </label>
                }
            </div>
        </div>

        <div style="margin-top: 20px;">
            <button @onclick="UpdateTeacher" style="padding: 8px 20px; background-color: #007bff; color: white; border: none; border-radius: 4px;">Сохранить</button>
            <button @onclick="Cancel" style="margin-left: 10px; padding: 8px 20px;">Отмена</button>
        </div>
    </div>
}

@code {
    private BlazorAcademyHWContext context = default!;
    private Teachers? teacher;
    private List<Disciplines> allDisciplines = new();
    private List<short> selectedDisciplines = new();
    private bool isLoading = true;

    [Parameter] public int teacher_id { get; set; }

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        allDisciplines = await context.Disciplines.ToListAsync();
        await LoadData();
    }

    protected override async Task OnParametersSetAsync()
    {
        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        
        try
        {
            if (teacher_id > 0)
            {
                teacher = await context.Teachers
                    .Include(t => t.TeacherDisciplines)
                    .FirstOrDefaultAsync(t => t.teacher_id == teacher_id);

                if (teacher != null)
                {
                    selectedDisciplines = teacher.TeacherDisciplines?
                        .Select(td => td.discipline_id).ToList() ?? new List<short>();
                }
            }
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ошибка: {ex.Message}");
        }
        finally
        {
            isLoading = false;
            StateHasChanged();
        }
    }

    private void ToggleDiscipline(short disciplineId)
    {
        if (selectedDisciplines.Contains(disciplineId))
            selectedDisciplines.Remove(disciplineId);
        else
            selectedDisciplines.Add(disciplineId);
    }

    private async Task UpdateTeacher()
    {
        if (teacher == null) return;

        var existingDisciplines = await context.TeacherDisciplines
            .Where(td => td.teacher_id == teacher.teacher_id)
            .ToListAsync();

        context.TeacherDisciplines.RemoveRange(existingDisciplines);

        foreach (var disciplineId in selectedDisciplines)
        {
            context.TeacherDisciplines.Add(new TeacherDiscipline
            {
                teacher_id = teacher.teacher_id,
                discipline_id = disciplineId
            });
        }

        await context.SaveChangesAsync();
        Navigation.NavigateTo("/teachers");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/teachers");
    }
}
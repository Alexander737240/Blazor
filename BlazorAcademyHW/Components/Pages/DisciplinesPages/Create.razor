@page "/disciplines/create"
@rendermode InteractiveServer
@using Microsoft.EntityFrameworkCore
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory
@inject NavigationManager Navigation

<PageTitle>Создание дисциплины</PageTitle>

<h1>Создание дисциплины</h1>

<div style="margin-bottom: 20px;">
    <a href="/disciplines">Назад к списку</a>
</div>

@if (errorMessage != null)
{
    <div style="padding: 10px; background-color: #f8d7da; color: #721c24; border-radius: 5px; margin-bottom: 15px;">
        @errorMessage
    </div>
}

<div style="width: 500px;">
    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Название дисциплины:</label>
        <input @bind="disciplineName" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Количество занятий:</label>
        <input type="number" @bind="numberOfLessons" style="width: 100%; padding: 8px;" />
    </div>

    <div style="margin-bottom: 15px;">
        <label style="display: block; margin-bottom: 5px;">Преподаватели, которые могут вести дисциплину:</label>
        <div style="padding: 10px; border: 1px solid #ddd; border-radius: 5px; max-height: 200px; overflow-y: auto;">
            @foreach (var teacher in allTeachers)
            {
                <label style="display: block; margin-bottom: 5px;">
                    <input type="checkbox"
                           value="@teacher.teacher_id"
                           checked="@selectedTeachers.Contains(teacher.teacher_id)"
                           @onchange="@(() => ToggleTeacher(teacher.teacher_id))" />
                    @teacher.last_name @teacher.first_name @teacher.middle_name
                </label>
            }
        </div>
    </div>

    <div style="margin-top: 20px;">
        <button @onclick="SaveDiscipline" style="padding: 8px 20px; background-color: #28a745; color: white; border: none; border-radius: 4px;">Сохранить</button>
        <button @onclick="Cancel" style="margin-left: 10px; padding: 8px 20px;">Отмена</button>
    </div>
</div>

@code {
    private BlazorAcademyHWContext context = default!;
    private string disciplineName = "";
    private byte numberOfLessons = 0;
    private List<short> selectedTeachers = new();
    private List<Teachers> allTeachers = new();
    private string? errorMessage = null;

    protected override async Task OnInitializedAsync()
    {
        context = DbFactory.CreateDbContext();
        allTeachers = await context.Teachers.ToListAsync();
    }

    private void ToggleTeacher(short teacherId)
    {
        if (selectedTeachers.Contains(teacherId))
            selectedTeachers.Remove(teacherId);
        else
            selectedTeachers.Add(teacherId);
    }

    private async Task SaveDiscipline()
    {
        errorMessage = null;
        
        if (string.IsNullOrWhiteSpace(disciplineName))
        {
            errorMessage = "Введите название дисциплины";
            return;
        }

        short nextId = 1;
        if (await context.Disciplines.AnyAsync())
        {
            nextId = (short)(await context.Disciplines.MaxAsync(d => d.discipline_id) + 1);
        }

        var discipline = new Disciplines
        {
            discipline_id = nextId,
            discipline_name = disciplineName,
            number_of_lessons = numberOfLessons
        };

        context.Disciplines.Add(discipline);
        await context.SaveChangesAsync();

        foreach (var teacherId in selectedTeachers)
        {
            var teacherDiscipline = new TeacherDiscipline
            {
                teacher_id = teacherId,
                discipline_id = discipline.discipline_id
            };
            context.TeacherDisciplines.Add(teacherDiscipline);
        }
        
        if (selectedTeachers.Any())
        {
            await context.SaveChangesAsync();
        }

        Navigation.NavigateTo("/disciplines");
    }

    private void Cancel()
    {
        Navigation.NavigateTo("/disciplines");
    }
}
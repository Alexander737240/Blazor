@page "/disciplines"
@using Microsoft.EntityFrameworkCore
@using Microsoft.AspNetCore.Components.QuickGrid
@using BlazorAcademyHW.Models
@using BlazorAcademyHW.Data
@implements IAsyncDisposable
@rendermode InteractiveServer
@inject IDbContextFactory<BlazorAcademyHW.Data.BlazorAcademyHWContext> DbFactory

<PageTitle>Index</PageTitle>

<h1>Дисциплины</h1>

<p>
    <a href="disciplines/create">Create New</a>
</p>

<div>
    <QuickGrid Class="table" Items="context.Disciplines" Pagination="pagination">
        <PropertyColumn Class="disc-name" Property="disciplines => disciplines.discipline_name" Title="Название дициплины" Sortable="true" />
        <PropertyColumn Class="number-of-lessons" Property="disciplines => disciplines.number_of_lessons" Title="Количество занятий" Sortable="true" />

        <TemplateColumn Context="discipline">
            <a href="@($"/disciplines/edit/{discipline.discipline_id}")">Edit</a> |
            <a href="@($"/disciplines/details/{discipline.discipline_id}")">Details</a> |
            <a href="@($"/disciplines/delete/{discipline.discipline_id}")">Delete</a>
        </TemplateColumn>
    </QuickGrid>
</div>

<Paginator State="pagination" />

@code {
    private PaginationState pagination = new PaginationState { ItemsPerPage = 10 };
    private BlazorAcademyHWContext context = default!;

    protected override void OnInitialized()
    {
        context = DbFactory.CreateDbContext();
    }

    public async ValueTask DisposeAsync() => await context.DisposeAsync();
}
